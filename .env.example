# =============================================================================
# Platypus Environment Configuration (Docker Compose)
# =============================================================================
# Copy this file to .env and edit the values below.
#
#   cp .env.example .env
#
# Docker Compose loads .env automatically. Variables defined here are injected
# into both the backend and frontend services via env_file.
# =============================================================================

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------

# A secure random string used to sign auth tokens (minimum 32 characters).
# Generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET="change-me-to-a-random-string-at-least-32-chars"

# Credentials for the initial admin user created on first startup.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="admin123"

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------

# IANA timezone name (e.g., "America/New_York", "Europe/London").
# Used for schedule execution and log timestamps. Defaults to UTC.
TIMEZONE="UTC"

# How often (in milliseconds) the background memory extraction job runs.
# Default: 300000 (5 minutes)
# MEMORY_EXTRACTION_INTERVAL_MS=300000

# Maximum number of scheduled agent runs to execute in parallel.
# Default: 5
# SCHEDULE_MAX_CONCURRENT=5

# Log level for the backend server. Options: debug, info, warn, error.
# Default: info
# LOG_LEVEL=info

# Comma-separated list of allowed CORS origins. Must include the URL where
# users access the frontend in their browser.
ALLOWED_ORIGINS="http://localhost:3000"

# The public URL of the frontend, used for generating resource links in tool
# responses. Change this if you expose Platypus on a different host or port.
FRONTEND_URL="http://localhost:3000"

# The public URL of the backend API. Used by the frontend for client-side
# requests and by better-auth for callbacks and redirects.
BACKEND_URL="http://localhost:4000"

# Set to "true" to allow the fetch tool to ignore robots.txt restrictions.
# Default: false
# FETCH_TOOL_IGNORE_ROBOTS_TXT=false

# -----------------------------------------------------------------------------
# Storage (backend only)
# -----------------------------------------------------------------------------

# Storage backend for file attachments. Options: disk, s3
STORAGE_BACKEND=disk

# Path inside the container where files are stored when using disk storage.
# This should match the volume mount in compose.yaml.
STORAGE_DISK_PATH=/data/files

# To use S3-compatible storage, set STORAGE_BACKEND=s3 and uncomment the
# variables below.
# STORAGE_S3_BUCKET=my-bucket
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_ENDPOINT=https://s3.amazonaws.com
# STORAGE_S3_ACCESS_KEY_ID=your-access-key
# STORAGE_S3_SECRET_ACCESS_KEY=your-secret-key

# Optional: public URL to serve files directly from your storage provider
# instead of proxying through the backend (e.g., via CDN).
# STORAGE_PUBLIC_URL=https://my-bucket.s3.amazonaws.com

# -----------------------------------------------------------------------------
# Frontend (optional)
# -----------------------------------------------------------------------------

# Base path for the frontend application (e.g., "/platypus").
# Only needed if you serve Platypus behind a reverse proxy with a path prefix.
# BASE_PATH=
