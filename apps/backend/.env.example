NODE_OPTIONS="--disable-warning=ExperimentalWarning"
PORT="4001"
ALLOWED_ORIGINS="http://localhost:3001"
DATABASE_URL=postgres://postgres:mypassword@localhost:5432/postgres
BETTER_AUTH_SECRET=your-secret-key-min-32-chars
BETTER_AUTH_URL=http://localhost:4001
INVITATION_EXPIRY_DAYS=7
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
LOG_LEVEL=info
# IANA timezone e.g. "America/New_York", "Europe/London", "Asia/Tokyo", etc.
# Defaults to UTC if not set
TIMEZONE=UTC

# Comma-separated OPTIONAL plugins to load and enable at boot (fail-loud on error).
# For these, list membership IS the enable switch (ADR-0013). The essential core
# tool sets load unconditionally and are NOT listed here -- listing one is a fatal
# error. So an empty value is valid: you still get the built-in core tools, just
# none of the optional plugins below. The default is "@platypus/web-fetch"; drop it
# to deny network egress in isolation. The Docker sandbox backend is opt-in: add
# "@platypus/docker" -- it is intentionally NOT in the default.
PLATYPUS_PLUGINS=@platypus/web-fetch

# Deploy-time, Operator-owned plugin config/credentials -- a single JSON object
# keyed by plugin NAME (the manifest name; for a third-party plugin a short slug,
# NOT the npm package specifier you list above). Each entry is an optional
# "config" (non-secret) and "credentials" (secret) block, validated at boot
# against the plugin's manifest schemas (fail-loud); a key matching no loaded
# plugin is also a fatal error. The one block is shared deployment-wide across all
# of that plugin's contributions and every tenant -- distinct from per-Workspace
# Sandbox config. Unset by default; treat like any secret-bearing env var.
# PLATYPUS_PLUGIN_CONFIG={"@platypus/docker":{"config":{"allowedNetworks":["shared-services","public-tools"]}},"cloud-sandbox":{"config":{"region":"eu"},"credentials":{"apiToken":"dtn_live_..."}}}

# Memory extraction configuration
MEMORY_EXTRACTION_INTERVAL_MS=300000  # 5 minutes

# Schedule scheduler configuration
SCHEDULE_SCHEDULER_INTERVAL_MS=60000  # 1 minute
SCHEDULE_MAX_CONCURRENT=5  # Max parallel schedule executions

# Fetch tool configuration
# Set to true to skip robots.txt checks when fetching URLs
FETCH_TOOL_IGNORE_ROBOTS_TXT=false

# Storage backend: "disk" (default) or "s3"
STORAGE_BACKEND=disk

# Disk storage path (when STORAGE_BACKEND=disk)
STORAGE_DISK_PATH=./data/files

# Optional: public URL for direct file access (bypasses /files proxy endpoint)
# e.g. https://mybucket.s3.amazonaws.com or a CDN URL
# STORAGE_PUBLIC_URL=

# S3 storage (when STORAGE_BACKEND=s3)
# STORAGE_S3_BUCKET=
# STORAGE_S3_REGION=
# STORAGE_S3_ENDPOINT=
# STORAGE_S3_ACCESS_KEY_ID=
# STORAGE_S3_SECRET_ACCESS_KEY=

# Trigger run timeouts (unattended Agent runs)
TRIGGER_PER_STEP_TIMEOUT_MS=600000  # idle timeout between steps (10 min)
TRIGGER_PER_RUN_TIMEOUT_MS=3600000  # wall-clock timeout per run (60 min)

# Frontend URL for generating resource links in tool responses
FRONTEND_URL=http://localhost:3001

# Agent run timeout ceilings (milliseconds). These are the hard upper bounds an
# org admin can configure down to via the org settings UI — an org override can
# lower a timeout but never raise it past these values. Unset = the hardcoded
# defaults shown below.
# Chat-driven runs (defaults: 10 min total, 2 min per step):
# RUN_PER_RUN_TIMEOUT_MS=600000
# RUN_PER_STEP_TIMEOUT_MS=120000
# Trigger-driven runs (defaults: 60 min total, 10 min per step):
# TRIGGER_PER_RUN_TIMEOUT_MS=3600000
# TRIGGER_PER_STEP_TIMEOUT_MS=600000