# Backend URL for client-side requests (browser to backend)
BACKEND_URL=http://localhost:4001

# Internal backend URL for server-side requests (SSR within Docker network)
# Only needed when running in Docker - leave unset for local development
# INTERNAL_BACKEND_URL=http://backend:4000

# Optional base path for deploying under a subpath (e.g. /platypus-app)
# BASE_PATH=